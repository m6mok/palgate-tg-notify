# Copy to .dev.env and fill in real values (see docs/configuration.md).
# .dev.env is gitignored — never commit it.

# Palgate
DEVICE_ID=
USER_ID=
SESSION_TOKEN=
SESSION_TOKEN_TYPE=1
URL_USER_LOG=https://api1.pal-es.com/v1/bt/device/{device_id}/log?sn=true
TZ=3

# Telegram
TELEGRAM_API_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_LOG_CHAT_ID=

# Max messenger channel (optional — leave empty to disable)
MAX_API_TOKEN=
MAX_CHAT_ID=0

# Rollback via ops bot (optional — leave empty to disable /rollback)
GITHUB_TOKEN=

# Mock gate entries via ops bot (optional — leave 0 to disable /mock).
# The prestable notification chat the fabricated entries are posted to.
PRESTABLE_TELEGRAM_CHAT_ID=0

# Telegram identity enrichment (optional — resolve phone → Telegram profile).
# Needs a user account (my.telegram.org) and a one-time login.
RESOLVE_ENABLED=false
TG_API_ID=0
TG_API_HASH=
# File session (local): `make login` writes TG_SESSION.session
TG_SESSION=data/telethon
# StringSession (release server): `make login-string`, paste the blob here.
# When set, it takes precedence over TG_SESSION. Treat like a password.
# TG_SESSION_STRING=
# Anti-flood knobs (safe defaults; tune only if needed):
# RESOLVE_MIN_INTERVAL=5
# RESOLVE_PER_HOUR=20
# RESOLVE_PER_DAY=150
# RESOLVE_POSITIVE_TTL=2592000
# RESOLVE_NEGATIVE_TTL=259200

# Polling
CRON_DELAY=60
