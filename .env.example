# Device ID (must match one of the device_ids in mock_server/config.json)
DEVICE_ID=4G12345678

# User ID (phone number in format 79*********)
USER_ID=79123456789

# Session Token (hex string, 16 bytes)
SESSION_TOKEN=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4

# Session Token Type (0 for phone)
SESSION_TOKEN_TYPE=0

# PalGate API URL (for production)
URL_USER_LOG=https://example.com/log

# Timezone offset in hours
TZ=3

# Telegram API Token
TELEGRAM_API_TOKEN=your_telegram_bot_token

# Telegram Chat ID for notifications
TELEGRAM_CHAT_ID=123456789

# Telegram Chat ID for logs
TELEGRAM_LOG_CHAT_ID=987654321

# Cron delay in seconds
CRON_DELAY=10

# Environment (dev or stable)
ENVIRONMENT=dev
